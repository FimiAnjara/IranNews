Options +FollowSymlinks
RewriteEngine On

# Cache des assets statiques
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/css "access plus 7 days"
	ExpiresByType text/javascript "access plus 7 days"
	ExpiresByType application/javascript "access plus 7 days"
	ExpiresByType application/x-javascript "access plus 7 days"
	ExpiresByType image/png "access plus 7 days"
	ExpiresByType image/jpeg "access plus 7 days"
	ExpiresByType image/gif "access plus 7 days"
	ExpiresByType image/svg+xml "access plus 7 days"
	ExpiresByType image/webp "access plus 7 days"
	ExpiresByType image/x-icon "access plus 7 days"
	ExpiresByType font/woff "access plus 7 days"
	ExpiresByType font/woff2 "access plus 7 days"
	ExpiresByType font/ttf "access plus 7 days"
	ExpiresByType font/otf "access plus 7 days"
	ExpiresByType application/vnd.ms-fontobject "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
	<FilesMatch "\.(css|js|mjs|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf|eot)$">
		Header set Cache-Control "public, max-age=604800"
	</FilesMatch>
</IfModule>

# Compression Gzip
<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/plain
	AddOutputFilterByType DEFLATE text/html
	AddOutputFilterByType DEFLATE text/xml
	AddOutputFilterByType DEFLATE text/css
	AddOutputFilterByType DEFLATE text/javascript
	AddOutputFilterByType DEFLATE application/javascript
	AddOutputFilterByType DEFLATE application/json
	AddOutputFilterByType DEFLATE application/xml
	AddOutputFilterByType DEFLATE application/xhtml+xml
	AddOutputFilterByType DEFLATE image/svg+xml

	<IfModule mod_headers.c>
		Header append Vary Accept-Encoding
	</IfModule>
</IfModule>

# Concatenation dynamique des assets via SSI
<FilesMatch "\.combined\.js$">
	Options +Includes
	AddOutputFilterByType INCLUDES application/javascript application/json
	SetOutputFilter INCLUDES
</FilesMatch>
<FilesMatch "\.combined\.css$">
	Options +Includes
	AddOutputFilterByType INCLUDES text/css
	SetOutputFilter INCLUDES
</FilesMatch>

# Exemption pour les uploads partages (alias Apache)
RewriteCond %{REQUEST_URI} ^/uploads/
RewriteRule ^ - [L]

# Ne pas rewriter les fichiers et dossiers existants
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Bloquer l'acces direct aux dossiers sensibles
RewriteRule ^(app|config|database|docker|backoffice|frontoffice) - [F,L]

# Article: /article-5 ou /article-5-mon-slug
RewriteRule ^article-([0-9]+)(-[a-z0-9-]+)?/?$ index.php?page=article&id=$1 [L,QSA]

# Categorie: /categorie-politique
RewriteRule ^([a-z0-9-]+)/?$ index.php?page=categorie&category=$1 [L,QSA]

# Recherche: /recherche-mon-query
RewriteRule ^recherche-(.+)/?$ index.php?page=recherche&q=$1 [L,QSA]

# API endpoints (utile pour tests directs et SEO friendly API)
RewriteRule ^api-news/?$ index.php?page=api-news [L,QSA]
RewriteRule ^api-categories/?$ index.php?page=api-categories [L,QSA]

# Pages simples
RewriteRule ^(accueil|a-propos|contact|connexion|inscription|deconnexion)/?$ index.php?page=$1 [L,QSA]

# Rediriger vers index.php par defaut si rien ne correspond
RewriteRule ^(.*)$ index.php?route=$1 [L,QSA]
